<%= form_with(model: recipe, data: { controller: "nested-form" }) do |form| %>
  <% if recipe.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(recipe.errors.count, "error") %> prohibited this recipe from being saved:</h2>
      <ul>
        <% recipe.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, style: "display: block" %>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :photo, "Recipe photo", style: "display: block" %>
    <%= form.file_field :photo, accept: "image/*" %>
    <% if recipe.photo.attached? %>
      <%= image_tag recipe.photo, style: "max-width: 200px; border-radius: 8px; margin-top: 8px;" %>
    <% end %>
  </div>

  <div>
    <%= form.label :description, style: "display: block" %>
    <%= form.textarea :description %>
  </div>

  <div>
    <%= form.label :cooking_time, style: "display: block" %>
    <%= form.number_field :cooking_time %>
  </div>

  <div>
    <%= form.label :servings, style: "display: block" %>
    <%= form.number_field :servings %>
  </div>

  <div>
    <%= form.label :category, style: "display: block" %>
    <%= form.select :category, ["Breakfast", "Lunch", "Dinner", "Dessert", "Drinks"], include_blank: "Select a category" %>
  </div>

  <div>
    <%= form.label :instructions, style: "display: block" %>
    <%= form.textarea :instructions %>
  </div>

  <h3>Ingredients</h3>
  <div data-nested-form-target="container">
    <%= form.fields_for :ingredients do |ingredient_form| %>
      <%= render "ingredient_fields", ingredient_form: ingredient_form %>
    <% end %>
  </div>

  <template data-nested-form-target="template">
    <%= form.fields_for :ingredients, Ingredient.new, child_index: "NEW_RECORD" do |ingredient_form| %>
      <%= render "ingredient_fields", ingredient_form: ingredient_form %>
    <% end %>
  </template>

  <button data-action="nested-form#add">Add Ingredient</button>

  <div>
    <%= form.submit %>
  </div>
<% end %>
