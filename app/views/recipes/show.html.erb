<p style="color: green"><%= notice %></p>

<%= render @recipe %>

<div>
  <%= button_to (Current.user.favorites.exists?(recipe: @recipe) ? "Unfavorite" : "Favorite"), toggle_favorite_recipe_path(@recipe), method: :post %>
</div>

<div>
  <% if @recipe.user == Current.user %>
    <%= link_to "Edit this recipe", edit_recipe_path(@recipe) %> |
    <%= button_to "Destroy this recipe", @recipe, method: :delete %>
  <% end %>
  <%= link_to "Back to recipes", recipes_path %>
</div>

<h3>Reviews</h3>
<% @recipe.reviews.each do |review| %>
  <div style="border: 1px solid #ddd; padding: 8px; margin-bottom: 8px;">
    <strong><%= review.user.name %></strong> rated it <%= review.rating %>/5
    <p><%= review.comment %></p>
    <% if review.user == Current.user %>
      <%= button_to "Delete review", recipe_review_path(@recipe, review), method: :delete %>
    <% end %>
  </div>
<% end %>

<h4>Leave a review</h4>
<%= form_with model: @review, url: recipe_reviews_path(@recipe) do |form| %>
  <div>
    <%= form.label :rating %>
    <%= form.select :rating, [1, 2, 3, 4, 5] %>
  </div>
  <div>
    <%= form.label :comment %>
    <%= form.textarea :comment %>
  </div>
  <%= form.submit "Post Review" %>
<% end %>
